# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# ---- PostgreSQL ----
DATABASE_URL=postgresql+psycopg://your_db_user:your_db_password@localhost:5432/healthcare

# ---- JWT (auth task, this sprint) ----
# Generate a long random string, e.g.  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- AI provider (later sprint) ----
AI_API_KEY=your_api_key_here
